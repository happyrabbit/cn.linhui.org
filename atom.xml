<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
 
 <title>Hey : )</title>
 <link href="https://cn.linhui.org/atom.xml" rel="self"/>
 <link href="https://cn.linhui.org/"/>
 <updated>{{ site.time | date_to_xmlschema }}</updated>
 <id>https://cn.linhui.org</id>
 <author>
   <name>Hui Lin</name>
   <email>longqiman@gmail.com</email>
 </author>

 {% for post in site.posts %}
 <entry>
   <title>{{ post.title }}</title>
   <link href="https://cn.linhui.org{{ post.url }}"/>
   <updated>{{ post.date | date_to_xmlschema }}</updated>
   <id>https://cn.linhui.org{{ post.id }}</id>
   <content type="html">{{ post.content | xml_escape }}</content>
 </entry>
 {% endfor %}

 
</feed>
